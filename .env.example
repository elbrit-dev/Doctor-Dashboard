# Copy this file to ".env" and fill in your ERPNext UAT details.
# .env is gitignored — credentials never get committed or shipped to the browser.

# Base URL of your ERPNext UAT site (no trailing slash)
ERPNEXT_URL=https://your-uat-site.example.com

# API key + secret for an ERPNext user with READ access to Lead.
# Generate in ERPNext: User > (your API user) > Settings > API Access > Generate Keys.
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Port the proxy listens on (optional; the Vite dev server proxies /api here).
PROXY_PORT=8787

# ── Google Drive folder (server-side; NO user login) ─────────────────────────
# The server lists + downloads the shared folder's sheets on everyone's behalf,
# so the dashboard shows the files with NO Google popup/login. Configure ONE of
# the two auth methods below, plus the folder id.
#
# The folder id — copy it from the folder's Drive URL:
#   https://drive.google.com/drive/folders/<THIS_IS_THE_FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=

# METHOD A — Service account (recommended; folder stays PRIVATE):
#   1. Google Cloud Console → enable the "Google Drive API".
#   2. Create a Service Account → Keys → Add key → JSON → download it.
#   3. Share the Drive folder with the service account's client_email (Viewer).
#   4. Paste the WHOLE key JSON on one line here (or use the KEY_FILE var).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ... }
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/absolute/path/to/service-account.json

# METHOD B — API key (folder must be "Anyone with the link can view"):
#   Google Cloud Console → enable the "Google Drive API" → create an API key.
#   Use an UNRESTRICTED key (or one without an HTTP-referrer restriction — the
#   server has no referrer). Then set the folder's sharing to link-viewable.
# GOOGLE_DRIVE_API_KEY=your_server_api_key_here
