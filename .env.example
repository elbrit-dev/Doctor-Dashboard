# Copy this file to ".env" and fill in your ERPNext UAT details.
# .env is gitignored — credentials never get committed or shipped to the browser.

# Base URL of your ERPNext UAT site (no trailing slash)
ERPNEXT_URL=https://your-uat-site.example.com

# API key + secret for an ERPNext user with READ access to Lead.
# Generate in ERPNext: User > (your API user) > Settings > API Access > Generate Keys.
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Port the proxy listens on (optional; the Vite dev server proxies /api here).
PROXY_PORT=8787

# ── Google Drive file picker (optional) ──────────────────────────────────────
# Lets "Choose from Google Drive" open the Google Picker so a sheet can be
# selected straight from Drive. These are PUBLIC client identifiers (safe to
# ship to the browser), NOT secrets. Set up in Google Cloud Console:
#   1. Create/enable a project; enable the "Google Picker API" and "Google Drive API".
#   2. Create an API key → put it in VITE_GOOGLE_API_KEY.
#   3. Create an OAuth 2.0 Client ID (type: Web application); add this site's
#      origin (e.g. http://localhost:5173 and the Netlify URL) under
#      "Authorized JavaScript origins" → put the client ID in VITE_GOOGLE_CLIENT_ID.
# VITE_-prefixed vars are baked into the frontend build by Vite.
VITE_GOOGLE_API_KEY=your_google_api_key_here
VITE_GOOGLE_CLIENT_ID=your_oauth_web_client_id_here.apps.googleusercontent.com

# Optional: lock the picker to ONE Drive folder so users only see the sheets in
# it (not their whole Drive). Copy the id from the folder's URL:
#   https://drive.google.com/drive/folders/<THIS_IS_THE_FOLDER_ID>
# Leave blank to let users browse all of their Drive.
VITE_GOOGLE_DRIVE_FOLDER_ID=
