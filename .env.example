# Copy this file to ".env" and fill in your ERPNext UAT details.
# .env is gitignored — credentials never get committed or shipped to the browser.

# Base URL of your ERPNext UAT site (no trailing slash)
ERPNEXT_URL=https://your-uat-site.example.com

# API key + secret for an ERPNext user with READ access to Lead.
# Generate in ERPNext: User > (your API user) > Settings > API Access > Generate Keys.
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Port the proxy listens on (optional; the Vite dev server proxies /api here).
PROXY_PORT=8787
